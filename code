void computerVsPlayer()
{
	string playerName;
	cout << "Enter your name: " << endl;
	cin >> playerName;
	while (true)
	{
		system("cls");
		showBoard();
		// Player X's Turn
		if (countBoard('X') == countBoard('O'))
		{
			cout << playerName << "'s Turn." << endl;
			XPlayerChoice();
		}
		// Computer's Turn (O)
		else
		{
			computerChoice();
		}
		char winner = checkWinner();
		if (winner == 'X')
		{
			system("cls");
			showBoard();
			cout << playerName << " Won the game!!" << endl;
			break;
		}

		else if (winner == 'O')
		{
			system("cls");
			showBoard();
			cout << "Haha! This was too easy, I won, You LOSE!!!" << endl;
			break;
		}

		else if (winner == 'D')
		{
			system("cls");
			showBoard();
			cout << "Game is a draw." << endl;
			break;

		}

	}
}

void computerChoice()
{
	srand(time(0));
	int choice;
	do
	{
		choice = rand() % 9; // range 0-8
	}

	while (board[choice] != ' ');
	{
		board[choice] = 'O';
	}
}

void XPlayerChoice()
{

	while (true)
	{
		cout << "Select your position (1-9): ";
		int choice;
		cin >> choice;
		choice--; //<-- computer logic starts at 0, so by doing this, the player doesn't have to worry about subtracting 1 to their desired position on the board. 

		if (choice < 0 || choice > 8)
		{
			cout << "Invalid input!! Choose a number 1-9." << endl;
		}
		else if (board[choice] != ' ')
		{
			cout << "Hey! That spot's taken! Choose an empty position." << endl;
		}

		else 
		{
			board[choice] = 'X';
			break;
		}
	}
}

